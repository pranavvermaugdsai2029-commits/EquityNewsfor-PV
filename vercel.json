{
"version": 2,
"builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
    { "src": "server.js", "use": "@vercel/node" }
],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
]
}
